def compose_list_message(number, titulo, body, pie, button_caption):
    data = {
        "messaging_product": "whatsapp",
        "recipient_type": "individual",
        "to": number,
        "type": "interactive",
        "interactive": {
                "type": "list",
                "header": {
                    "type": "text",
                    "text": titulo
                },
            "body": {
                    "text": body
                },
            "footer": {
                    "text": pie
                },
            "action": {
                    "button": button_caption,
                    "sections": [
                        {
                            "title": "Pagnifique",
                            "rows": [
                                {
                                    "id": "1001",
                                    "title": "Bagette Corto",
                                    "description": "Caja de 12u - $160"
                                },
                                {
                                    "id": "1002",
                                    "title": "Baguette Largo",
                                    "description": "Caja de 12u - $250"
                                },
                                {
                                    "id": "1003",
                                    "title": "Croissant Comun",
                                    "description": "Caja de 24u - $160 "
                                }
                            ]
                        }
                    ]
            }
        }
    }
    return data

