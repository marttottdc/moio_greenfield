[databases]
; Pool name = connection string to real Postgres
; Your app connects to PgBouncer and uses DB name "moio_greenfield"
moio_greenfield = host=POSTGRES_HOST port=5432 dbname=moio_greenfield

[pgbouncer]
listen_addr = *
listen_port = 6432
auth_type = md5
auth_file = /etc/pgbouncer/userlist.txt
pool_mode = transaction
max_client_conn = 500
default_pool_size = 25
min_pool_size = 10
reserve_pool_size = 5
reserve_pool_timeout = 3
server_lifetime = 3600
server_idle_timeout = 600
log_connections = 1
log_disconnections = 1
log_pooler_errors = 1
