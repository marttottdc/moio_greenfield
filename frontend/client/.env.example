# Canonical backend API origin for the frontend.
# Example: https://api.moiodigital.com/api/v1
# Local dev: leave empty or use VITE_API_ORIGIN= so requests go to same-origin /api (proxied by Express)
VITE_API_ORIGIN=https://api.moiodigital.com/api/v1

# Canonical websocket base for the frontend.
# Example: wss://api.moiodigital.com/ws
VITE_WS_BASE_URL=wss://api.moiodigital.com/ws

# Tenant-scoped API origin template. If no {tenant_host} placeholder is present,
# the frontend swaps the hostname with the authenticated tenant primary domain.
# Example: https://{tenant_host}/api/v1
VITE_TENANT_API_ORIGIN=https://{tenant_host}/api/v1

# Tenant-scoped websocket base template.
# Example: wss://{tenant_host}/ws
VITE_TENANT_WS_BASE_URL=wss://{tenant_host}/ws
